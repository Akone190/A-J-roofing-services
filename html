    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-links">
            <a href="#services">Services</a>
            <a href="#about">About</a>
            <a href="#testimonials">Reviews</a>
            <a href="#contact">Contact</a>
        </div>
        <p>📍 Voorhees Township, NJ</p>
        <p>&copy; 2024 A&J Attic Insulation Services & Roofing Services. All Rights Reserved.</p>
