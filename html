        </div>
    </section>

    <!-- Why Choose Us -->
    <section class="why-us">
        <h2>Why Choose A&J?</h2>
        <div class="why-grid">
            <div class="why-card">
                <div class="icon">⭐</div>
                <h3>Experienced Team</h3>
                <p>Years of experience serving Voorhees Township and surrounding NJ communities.</p>
            </div>
            <div class="why-card">
                <div class="icon">💰</div>
