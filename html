    <!-- Contact Section -->
    <section class="contact" id="contact">
        <div class="contact-info">
            <h2>Get In Touch</h2>
            <p>Ready to improve your home's insulation or roofing? Contact us today for a free estimate!</p>
            <div class="info-item">
                <span>📍</span>
                <span>Voorhees Township, NJ</span>
            </div>
            <div class="info-item">
                <span>📞</span>
